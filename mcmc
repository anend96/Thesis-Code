# Build representative detection data-points for MCMC likelihood
def _make_det_arrays(lit_radio, n_per_band=6):
    nus, lognufnus, sigmas = [], [], []
    for (nu, lmin, lmax, *_) in lit_radio:
        mid   = 0.5*(lmin + lmax)
        half  = 0.5*(lmax - lmin)
        sigma = max(half / 2.0, 0.35)
        for nu_i in np.linspace(nu*0.8, nu*1.2, n_per_band):
            nus.append(nu_i)
            lognufnus.append(mid)
            sigmas.append(sigma)
    return np.array(nus), np.array(lognufnus), np.array(sigmas)

NU_DET, LOGNUFNU_DET, SIGMA_DET = _make_det_arrays(LIT_RADIO)

# ============================================================
# LIKELIHOOD BUILDING BLOCKS
# ============================================================

def loglike_det(log_nufnu_obs, sigma_obs, log_nufnu_model):
    """Gaussian log-likelihood for a detection in log10(nuFnu) space."""
    return -0.5 * ((log_nufnu_obs - log_nufnu_model) / sigma_obs)**2

def loglike_ul(flux_lim, n_sigma, flux_model):
    """
    One-sided survival-function log-likelihood for an upper limit.
    sigma_noise = flux_lim / n_sigma
    logL = log Phi((flux_lim - flux_model) / sigma_noise)
    Returns 0 when flux_model << flux_lim, -inf when flux_model >> flux_lim.
    """
    sigma_noise = flux_lim / n_sigma
    z = (flux_lim - flux_model) / (np.sqrt(2.0) * sigma_noise)
    val = np.log(0.5 * (1.0 + erf(z)))
    return val if np.isfinite(val) else -1e30

# ============================================================
# MODULE 1 -- SPECTRAL INDEX FITTING
# ============================================================
# Model: log10(nuFnu) = log_norm + (1-alpha)*log10(nu/nu0)
#        where Snu ~ nu^{-alpha}  =>  nuFnu ~ nu^{1-alpha}
# Parameters: [log_norm, alpha]
#   log_norm: U(-17, -11)
#   alpha:    U(0, 5)

def spec_model(nu, log_norm, alpha):
    return log_norm + (1.0 - alpha) * np.log10(nu / NU0_HZ)

def logprior_spec(p):
    log_norm, alpha = p
    if -17.0 < log_norm < -11.0 and 0.0 < alpha < 5.0:
        return 0.0
    return -np.inf

def logpost_spec(p, nu_det, log_nufnu_det, sigma_det, ul_list):
    lp = logprior_spec(p)
    if not np.isfinite(lp):
        return -np.inf
    log_norm, alpha = p
    # Detections
    ll = np.sum(loglike_det(log_nufnu_det, sigma_det,
                             spec_model(nu_det, log_norm, alpha)))
    # Radio upper limits
    for (nu, nufnu_lim, n_sig, fluence, label, band) in ul_list:
        nufnu_model = 10.0 ** spec_model(nu, log_norm, alpha)
        ll += loglike_ul(nufnu_lim, n_sig, nufnu_model)
    return lp + ll

# ============================================================
# MODULE 2 -- SYNCHROTRON-SHOCK MODEL
# ============================================================
# Optical fluence scaling (Metzger+19; Beloborodov 2020):
#   F_opt = F_ref * (Ek/Ek_ref)^a * (epsB/epsB_ref)^b * (n/n_ref)^c
# Calibration: F_ref=1e-12 erg/cm2 at Ek=1e44, epsB=0.01, n=1, D=147Mpc, dt=1ms
# Parameters: [log_Ek, log_eps_B, log_n]
#   log_Ek:    U(42, 47)
#   log_eps_B: U(-4,  0)
#   log_n:     U(-5,  2)

_A = (P_SYNC + 3.0) / 4.0   # = 1.30
_B = (P_SYNC + 1.0) / 4.0   # = 0.80
_C = 0.5
_F_REF   = 1.0e-12
_EK_REF  = 1.0e44
_EB_REF  = 1.0e-2
_N_REF   = 1.0

def shock_F_opt(log_Ek, log_epsB, log_n):
    """Predicted optical fluence [erg/cm2] at 147 Mpc, dt=1ms."""
    return (_F_REF
            * (10.0**log_Ek   / _EK_REF) ** _A
            * (10.0**log_epsB / _EB_REF) ** _B
            * (10.0**log_n    / _N_REF)  ** _C)

def shock_F_xray(log_Ek, log_epsB, log_n):
    """
    Predicted 3-80 keV fluence [erg/cm2] at 147 Mpc, dt=1ms.
    The synchrotron peak lies near optical for typical parameters;
    the 3-80 keV band is above the cooling break -> F_X ~ 1% of F_opt
    (conservative, consistent with Beloborodov 2020 Fig. 3).
    """
    return 0.01 * shock_F_opt(log_Ek, log_epsB, log_n)

def logprior_shock(p):
    log_Ek, log_epsB, log_n = p
    if 42.0 < log_Ek < 47.0 and -4.0 < log_epsB < 0.0 and -5.0 < log_n < 2.0:
        return 0.0
    return -np.inf

def logpost_shock(p, F_opt_lim, n_sig_opt, F_xray_lim, n_sig_xray):
    lp = logprior_shock(p)
    if not np.isfinite(lp):
        return -np.inf
    log_Ek, log_epsB, log_n = p
    ll  = loglike_ul(F_opt_lim,  n_sig_opt,  shock_F_opt( log_Ek, log_epsB, log_n))
    ll += loglike_ul(F_xray_lim, n_sig_xray, shock_F_xray(log_Ek, log_epsB, log_n))
    return lp + ll

# ============================================================
# MODULE 3 -- MAGNETOSPHERIC EFFICIENCY
# ============================================================
# Model: E_X   = eta_X   * E_radio
#        E_opt = eta_opt * E_radio
# Parameters: [log_eta_X, log_eta_opt, log_E_radio]
#   log_eta_X:    U(-3, 10)
#   log_eta_opt:  U(-7,  5)
#   log_E_radio:  U(35, 40)   (Effelsberg: ~1e36-1e38 erg)
# Constraints:
#   LAXPC:   E_X   < 4.24e43 erg (3sigma)
#   AquEYE+: E_opt < 8.1e39 erg  (5sigma)

def logprior_eff(p):
    leX, leO, leR = p
    if -3.0 < leX < 10.0 and -7.0 < leO < 5.0 and 35.0 < leR < 40.0:
        return 0.0
    return -np.inf

def logpost_eff(p, E_X_lim, n_sig_X, E_opt_lim, n_sig_opt):
    lp = logprior_eff(p)
    if not np.isfinite(lp):
        return -np.inf
    leX, leO, leR = p
    E_r = 10.0**leR
    ll  = loglike_ul(E_X_lim,   n_sig_X,   10.0**leX * E_r)
    ll += loglike_ul(E_opt_lim, n_sig_opt, 10.0**leO * E_r)
    return lp + ll

# ============================================================
# METROPOLIS-HASTINGS SAMPLER
# ============================================================

def metropolis_hastings(logpost_fn, p0, proposal_sigma,
                        n_steps=300_000, burn_frac=0.40, thin=25, **kw):
    """
    Metropolis-Hastings sampler with Gaussian proposals.

    Parameters
    ----------
    logpost_fn     : callable -- log-posterior(params, **kw)
    p0             : array    -- starting position
    proposal_sigma : array    -- per-parameter Gaussian widths
    n_steps        : int      -- total iterations (default 300 000)
    burn_frac      : float    -- burn-in fraction  (default 0.40)
    thin           : int      -- thinning factor   (default 25)
    **kw passed verbatim to logpost_fn

    Returns
    -------
    chain       : ndarray (n_kept, n_params)
    accept_rate : float
    """
    p_cur  = np.asarray(p0, float)
    lp_cur = logpost_fn(p_cur, **kw)
    full   = np.empty((n_steps, len(p_cur)))
    n_acc  = 0

    for i in range(n_steps):
        p_prop = p_cur + RNG.standard_normal(len(p_cur)) * proposal_sigma
        lp_prop = logpost_fn(p_prop, **kw)
        if np.log(RNG.uniform()) < lp_prop - lp_cur:
            p_cur, lp_cur = p_prop, lp_prop
            n_acc += 1
        full[i] = p_cur

    burn  = int(burn_frac * n_steps)
    return full[burn::thin], n_acc / n_steps

# ============================================================
# CORNER PLOT UTILITY (pure matplotlib, no external deps)
# ============================================================

def corner_plot(chain, labels, truths=None):
    n = chain.shape[1]
    fig, axes = plt.subplots(n, n, figsize=(3.2*n, 3.2*n))
    if n == 1:
        axes = np.array([[axes]])

    for row in range(n):
        for col in range(n):
            ax = axes[row, col]
            if col > row:
                ax.set_visible(False)
                continue
            x = chain[:, col]
            y = chain[:, row]
            if row == col:
                ax.hist(x, bins=55, density=True, color="#4393C3",
                        histtype="stepfilled", alpha=0.75, lw=0)
                ax.hist(x, bins=55, density=True, color="#1B4F72",
                        histtype="step", lw=1.0)
                q16, q50, q84 = np.percentile(x, [16, 50, 84])
                ax.axvline(q50, color="k",        lw=1.5)
                ax.axvline(q16, color="k",        lw=0.9, ls="--")
                ax.axvline(q84, color="k",        lw=0.9, ls="--")
                if truths is not None and truths[col] is not None:
                    ax.axvline(truths[col], color="orangered", lw=1.8, ls=":")
                ax.set_title(f"{labels[col]}\n"
                             f"${q50:.2f}^{{+{q84-q50:.2f}}}_{{-{q50-q16:.2f}}}$",
                             fontsize=8, pad=3)
                ax.set_yticks([])
            else:
                ax.hexbin(x, y, gridsize=35, cmap="Blues",
                          mincnt=1, linewidths=0.2)
                if truths is not None:
                    if truths[col] is not None:
                        ax.axvline(truths[col], color="orangered", lw=1, ls=":")
                    if truths[row] is not None:
                        ax.axhline(truths[row], color="orangered", lw=1, ls=":")

            if row == n-1:
                ax.set_xlabel(labels[col], fontsize=9)
            else:
                ax.set_xticklabels([])
            if col == 0 and row != 0:
                ax.set_ylabel(labels[row], fontsize=9)
            else:
                ax.set_yticklabels([])

    plt.subplots_adjust(hspace=0.06, wspace=0.06)
    return fig

# ============================================================
# PLOT A -- BROADBAND SED
# ============================================================

def plot_sed(chain_spec, out):
    fig, ax = plt.subplots(figsize=(11.5, 6.5))
    nu_grid = np.logspace(7.5, 19.5, 400)

    # posterior band
    idx = RNG.integers(0, len(chain_spec), 350)
    for i in idx:
        ln, al = chain_spec[i]
        ax.plot(nu_grid, 10.0**spec_model(nu_grid, ln, al),
                color="#F39C12", alpha=0.04, lw=0.5)

    med_ln, med_al = np.median(chain_spec, axis=0)
    ax.plot(nu_grid, 10.0**spec_model(nu_grid, med_ln, med_al),
            color="darkorange", lw=2.2, ls="--",
            label=fr"MCMC median: $\alpha = {med_al:.2f}$")
    ax.plot(nu_grid, 10.0**spec_model(nu_grid, med_ln, 1.4),
            color="grey", lw=1.4, ls=":", alpha=0.7,
            label=r"$\alpha = 1.4$ (Bethapudi+23)")

    # Literature detection bands
    for (nu, lmin, lmax, label, col) in LIT_RADIO:
        ax.fill_between([nu*0.72, nu*1.38],
                        [10**lmin]*2, [10**lmax]*2,
                        alpha=0.32, color=col, zorder=2)
    ax.fill_between([], [], [], alpha=0.35, color="#2166AC",
                    label="Radio detections (literature)")

    # Literature ULs
    for (nu, nufnu_lim, n_sig, label, band) in LIT_UL:
        col = "#922B21" if band == "optical" else "#6C3483"
        ax.plot(nu, nufnu_lim, "v", color=col, ms=8, alpha=0.5, zorder=4)
        ax.annotate("", xy=(nu, nufnu_lim*0.38), xytext=(nu, nufnu_lim),
                    arrowprops=dict(arrowstyle="-|>", color=col, lw=1.2, alpha=0.5))

    # This-work ULs
    colors_band = {"radio": "#1B4F72", "optical": "#922B21", "xray": "#6C3483"}
    for (nu, nufnu_lim, n_sig, fluence, label, band) in UL_THIS_WORK:
        col = colors_band[band]
        ax.plot(nu, nufnu_lim, "v", color=col, ms=11, zorder=6, mew=0)
        ax.annotate("", xy=(nu, nufnu_lim*0.40), xytext=(nu, nufnu_lim),
                    arrowprops=dict(arrowstyle="-|>", color=col, lw=2.0))
        ax.text(nu, nufnu_lim*1.7,
                label.replace(" ", "\n"), ha="center", va="bottom",
                fontsize=6.0, color=col)

    ax.plot([], [], "v", color="#1B4F72", ms=10, label="Radio ULs, this work (6σ)")
    ax.plot([], [], "v", color="#922B21", ms=10, label="Optical UL, this work (5σ)")
    ax.plot([], [], "v", color="#6C3483", ms=10, label="LAXPC X-ray UL, this work (3σ)")

    # SGR 1935+2154
    ax.scatter(NU_SGR, NUFNU_SGR, marker="*", s=260,
               color="gold", edgecolors="k", lw=0.6, zorder=8,
               label="SGR 1935+2154 @ 147 Mpc")

    for txt, nu_t, y_t in [("Radio", 6e8, 3e-7),
                            ("Optical", 5e14, 3e-7),
                            ("X-ray", 5e17, 3e-7)]:
        ax.text(nu_t, y_t, txt, fontsize=9, color="0.45", ha="center")

    ax.set_xscale("log"); ax.set_yscale("log")
    ax.set_xlim(3e7, 5e19); ax.set_ylim(3e-27, 3e-6)
    ax.set_xlabel(r"Frequency $\nu$ [Hz]", fontsize=13)
    ax.set_ylabel(r"$\nu F_\nu$ [erg cm$^{-2}$ s$^{-1}$]", fontsize=13)
    ax.set_title("FRB 20180916B — Broadband SED with MCMC spectral index posterior",
                 fontsize=12)
    ax.legend(fontsize=8, ncol=2, loc="lower left", framealpha=0.88, edgecolor="0.7")
    plt.tight_layout()
    for ext in ("pdf", "png"):
        fig.savefig(f"{out}/sed_mcmc.{ext}", dpi=150, bbox_inches="tight")
    plt.close(fig)
    print("  -> sed_mcmc.pdf / .png")

