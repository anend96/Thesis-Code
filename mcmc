# ============================================================
# PLOT C -- SHOCK MODEL
# ============================================================

def plot_shock(chain_shock, out):
    labels_sh = [r"$\log_{10}(E_k /$ erg)",
                 r"$\log_{10}(\epsilon_B)$",
                 r"$\log_{10}(n /$ cm$^{-3}$)"]
    fig = corner_plot(chain_shock, labels=labels_sh)
    fig.suptitle("Shock model posterior   (AquEYE+ optical + LAXPC X-ray ULs)",
                 fontsize=10, y=1.01)
    for ext in ("pdf", "png"):
        fig.savefig(f"{out}/shock_corner.{ext}", dpi=150, bbox_inches="tight")
    plt.close(fig)
    print("  -> shock_corner.pdf / .png")

    # 2-D constraint maps
    log_Ek, log_eB, log_n = chain_shock.T
    fig2, axes = plt.subplots(1, 3, figsize=(15, 5))
    pairs = [
        (log_Ek, log_eB, labels_sh[0], labels_sh[1], [42,47], [-4,0]),
        (log_Ek, log_n,  labels_sh[0], labels_sh[2], [42,47], [-5,2]),
        (log_eB, log_n,  labels_sh[1], labels_sh[2], [-4,0],  [-5,2]),
    ]
    for ax, (x, y, xl, yl, xr, yr) in zip(axes, pairs):
        h = ax.hexbin(x, y, gridsize=45, cmap="YlGnBu", mincnt=1, linewidths=0.2)
        plt.colorbar(h, ax=ax, label="Counts")
        ax.set_xlabel(xl, fontsize=11); ax.set_ylabel(yl, fontsize=11)
        ax.set_xlim(xr); ax.set_ylim(yr)

    # AquEYE+ exclusion boundary in (Ek, epsB) plane (fixed n=n_ref=1)
    Ek_line = np.linspace(42, 47, 200)
    log_eB_boundary = (np.log10(3.1e-15 / _F_REF)
                       - _A * (Ek_line - np.log10(_EK_REF))) / _B + np.log10(_EB_REF)
    axes[0].plot(Ek_line, log_eB_boundary, color="orangered", lw=2.2, ls="--",
                 label="AquEYE+ exclusion boundary\n(n = 1 cm$^{-3}$)")
    mask = log_eB_boundary <= 0.0
    if mask.any():
        axes[0].fill_between(Ek_line[mask], log_eB_boundary[mask], 0.0,
                             alpha=0.18, color="orangered")
    axes[0].legend(fontsize=8)

    fig2.suptitle("FRB 20180916B -- Shock model: 2D marginalised parameter space",
                  fontsize=11, y=1.01)
    plt.tight_layout()
    for ext in ("pdf", "png"):
        fig2.savefig(f"{out}/shock_2d.{ext}", dpi=150, bbox_inches="tight")
    plt.close(fig2)
    print("  -> shock_2d.pdf / .png")

