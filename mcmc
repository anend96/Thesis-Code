    fig = corner_plot(chain_eff,
                      labels=[r"$\log_{10}(\eta_X)$",
                               r"$\log_{10}(\eta_{\rm opt})$",
                               r"$\log_{10}(E_{\rm radio} /$ erg)"])
    fig.suptitle("Magnetospheric efficiency posterior", fontsize=10, y=1.01)
    for ext in ("pdf", "png"):
        fig.savefig(f"{out}/efficiency_corner.{ext}", dpi=150, bbox_inches="tight")
    plt.close(fig)
    print("  -> efficiency_corner.pdf / .png")

    log_etaX, log_etaO, _ = chain_eff.T
    fig2, axes = plt.subplots(1, 2, figsize=(13, 5))

    for ax, data, xlabel, sgr_val in [
        (axes[0], log_etaX, r"$\log_{10}(\eta_X = E_X / E_{\rm radio})$",     5.0),
        (axes[1], log_etaO, r"$\log_{10}(\eta_{\rm opt} = E_{\rm opt} / E_{\rm radio})$", None),
    ]:
        ax.hist(data, bins=70, density=True, color="#1B7837",
                histtype="stepfilled", alpha=0.70, edgecolor="white", lw=0.4)
        q16, q50, q84 = np.percentile(data, [16, 50, 84])
        ax.axvline(q50, color="navy",     lw=1.8, ls=":",
                   label=f"Median = {q50:.2f}")
        ax.axvline(q84, color="orangered",lw=2.2, ls="--",
                   label=f"84th pct (UL) = {q84:.2f}")
        if sgr_val is not None:
            ax.axvline(sgr_val, color="goldenrod", lw=2.5,
                       label=r"SGR 1935+2154: $\eta_X \gtrsim 10^5$")
        ax.set_xlabel(xlabel, fontsize=11)
        ax.set_ylabel("Posterior density", fontsize=11)
        ax.legend(fontsize=9)

    axes[0].set_title(r"LAXPC: $E_X^{\rm iso} < 4.24\times10^{43}$ erg (3$\sigma$, 1 ms)",
                      fontsize=9)
    axes[1].set_title(r"AquEYE+: $E_{\rm opt}^{\rm iso} < 8.1\times10^{39}$ erg (5$\sigma$, 1 ms)",
                      fontsize=9)
    fig2.suptitle("FRB 20180916B -- Magnetospheric efficiency constraints vs. SGR 1935+2154",
                  fontsize=11)
    plt.tight_layout()
    for ext in ("pdf", "png"):
        fig2.savefig(f"{out}/efficiency_marginals.{ext}", dpi=150, bbox_inches="tight")
    plt.close(fig2)
    print("  -> efficiency_marginals.pdf / .png")

# ============================================================
# PLOT E -- TRACE PLOTS (convergence diagnostics)
# ============================================================

def plot_traces(chains, labels_list, names, out):
    for chain, labels, name in zip(chains, labels_list, names):
        n_p = chain.shape[1]
        fig, axes = plt.subplots(n_p, 1, figsize=(10, 2.5*n_p), sharex=True)
        if n_p == 1:
            axes = [axes]
        for ax, col, lab in zip(axes, chain.T, labels):
            ax.plot(col, lw=0.4, color="steelblue", alpha=0.9)
            ax.axhline(np.median(col), color="orangered", lw=1.0, ls="--")
            ax.set_ylabel(lab, fontsize=9)
        axes[-1].set_xlabel("Thinned sample index", fontsize=10)
        fig.suptitle(f"Trace plot -- {name}", fontsize=11)
        plt.tight_layout()
        safe = name.lower().replace(" ", "_")
        for ext in ("pdf", "png"):
            fig.savefig(f"{out}/trace_{safe}.{ext}", dpi=120, bbox_inches="tight")
        plt.close(fig)
        print(f"  -> trace_{safe}.pdf / .png")

